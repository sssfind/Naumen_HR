# Скопируйте в корень: cp .env.example .env
# Используется docker compose для backend

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/naumen_hr
SPRING_DATASOURCE_USERNAME=naumen
SPRING_DATASOURCE_PASSWORD=naumen
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_EXPIRATION_MS=86400000
ALLOWED_EMAIL_DOMAIN=naumen.ru
SPRING_PROFILES_ACTIVE=prod

# CORS: публичный URL фронта (https). Через запятую, если несколько. Переопределяет application-prod.yml
APP_CORS_ALLOWED_ORIGINS=https://jimmy-neutron.duckdns.org,http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
